model Notice {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  content        String
  type           String   @default("공지") @map("type")
  targetAudience String?  @map("target_audience")
  isImportant    Boolean  @default(false) @map("is_important")
  imageUrl       String?  @map("image_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("notices")
}

model ActivityLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  adminId     String?  @map("admin_id") @db.ObjectId
  adminName   String   @map("admin_name")
  action      String
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id") @db.ObjectId
  targetName  String?  @map("target_name")
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([createdAt])
  @@map("activity_logs")
}
