generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Admin {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  email      String    @unique
  password   String
  name       String
  phone      String?
  status     String    @default("active") @map("status")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("admin")
}

model Owner {
  id                      String    @id @default(auto()) @map("_id") @db.ObjectId
  email                   String?
  password                String
  name                    String
  phone                   String?
  branchNumber            String?   @map("branch_number")
  businessRegistrationNumber String? @map("business_registration_number")
  representativeName      String?   @map("representative_name")
  storeName               String?   @map("store_name")
  storeOpenDate           DateTime? @map("store_open_date")
  address                 String?   @map("address")
  detailAddress           String?   @map("detail_address")
  storeType               String?   @map("store_type")
  platform                String?   @map("platform")
  status                  String    @default("active") @map("status")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  stores                  Store[]

  @@map("store_owner")
}

model Store {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  type        String?
  location    String
  latitude    Float?
  longitude   Float?
  description String?
  imageUrl    String?  @map("image_url")
  ownerId     String?  @map("owner_id") @db.ObjectId
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  news        String?
  notice      String?
  parking     String?
  owner       Owner?   @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@map("store_mapping")
}

