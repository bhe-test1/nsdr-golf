model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Reservation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @map("user_id") @db.ObjectId
  storeId   String   @map("store_id") @db.ObjectId
  date      DateTime
  time      String
  players   Int?     @default(4)
  status    String   @default("PENDING")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([storeId])
  @@map("reservations")
}

model Login {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerId      String   @unique @map("owner_id") @db.ObjectId
  name         String
  email        String
  phone        String
  password     String
  branchNumber String?  @map("branch_number")
  status       String   @default("active") @map("status")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("login")
}

model Notice {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  content     String
  type        String   @default("공지") @map("type")
  isImportant Boolean  @default(false) @map("is_important")
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("notices")
}

model Price {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerId     String   @unique @map("owner_id") @db.ObjectId
  gamePrices  Json     @map("game_prices")
  foodPrices  Json     @map("food_prices")
  golfPrices  Json     @map("golf_prices")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("price")
}
