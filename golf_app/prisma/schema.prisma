generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  email              String    @unique
  password           String
  name               String
  phone              String
  resetToken         String?   @map("reset_token")
  resetTokenExpiry   DateTime? @map("reset_token_expiry")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  posts              Post[]
  comments           Comment[]
  favorites          Favorite[]

  @@map("users")
}
model Store {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  type        String?
  location    String
  latitude    Float?
  longitude   Float?
  description String?
  imageUrl    String?  @map("image_url")
  ownerId     String?  @map("owner_id") @db.ObjectId
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  news        String?
  notice      String?
  parking     String?
  price       Int?     @default(0)
  rating      Float?   @default(0)
  reviewCount Int?     @default(0) @map("review_count")
  favorites   Favorite[]

  @@index([ownerId])
  @@map("stores")
}
model Favorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  store     Store    @relation(fields: [storeId], references: [id])

  @@unique([userId, storeId])
  @@index([userId])
  @@index([storeId])
  @@map("favorites")
}

model Notice {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  content        String
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("notices")
}

model Post {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @map("user_id") @db.ObjectId
  title     String
  content   String
  category  String   @default("general")
  likes     Int      @default(0)
  isHot     Boolean  @default(false) @map("is_hot")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id])
  comments  Comment[]

  @@index([userId])
  @@map("posts")
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  postId    String   @map("post_id") @db.ObjectId
  userId    String   @map("user_id") @db.ObjectId
  content   String
  user      User     @relation(fields: [userId], references: [id])

  @@index([postId])
  @@index([userId])
  @@map("comments")
}

